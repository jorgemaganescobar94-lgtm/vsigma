# Entorno virtual local
.venv/

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd

# Variables secretas / API keys
.env
.env.*
*.env

# Logs
logs/
*.log

# Sistema
.DS_Store
Thumbs.db

# Temporales
data/tmp/
tmp/
.cache/

# Backups locales
*.bak
*.backup

# Local API cache / databases
data/cache/
data/cache/*.sqlite3
data/cache/*.sqlite3-wal
data/cache/*.sqlite3-shm
# Pytest cache
.pytest_cache/

.env
data/processed/**/api_enrichment/
data/processed/**/player_props/

# World Cup study CSV artifacts (regenerable data; keep the .py + *_report.txt)
analysis/worldcup/*_study*.csv
analysis/worldcup/*_probe*.csv

# Fase 4E auto referee-profile artifacts: the .csv is auto-committed by CI (kept), json+report are
